@model EduCodePlatform.ViewModels.RegisterViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Реєстрація";
}

@section FogCanvasSection {
    <link rel="stylesheet" href="~/css/fogCanvas.css" asp-append-version="true" />

    <canvas id="fog-canvas"></canvas>
    <script src="~/js/fogCanvas.js" asp-append-version="true"></script>

    <style>
        body {
            background-color: #000 !important;
            color: #fff;
        }
    </style>
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh; position: relative; z-index: 2;">
    <div class="hero-content text-center">
        <h2 class="glitch text-white mb-4">Реєстрація</h2>

        <form asp-action="Register" method="post" class="login-form mx-auto">
            @Html.AntiForgeryToken()

            <div class="mb-3 text-start">
                <label asp-for="Email" class="form-label text-light"></label>
                <input asp-for="Email" class="form-control bg-dark text-light border-secondary" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3 text-start">
                <label asp-for="Password" class="form-label text-light"></label>
                <input asp-for="Password" type="password" class="form-control bg-dark text-light border-secondary" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="mb-3 text-start">
                <label asp-for="ConfirmPassword" class="form-label text-light"></label>
                <input asp-for="ConfirmPassword" type="password" class="form-control bg-dark text-light border-secondary" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-outline-light w-100">Зареєструватися</button>

            <div class="mt-3">
                <a asp-action="Login" class="text-info">Вже маєте акаунт? Увійти</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
