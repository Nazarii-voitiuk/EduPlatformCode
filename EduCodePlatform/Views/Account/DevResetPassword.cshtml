@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Dev - Скидання паролю";
}

@section FogCanvasSection {
    <link rel="stylesheet" href="~/css/fogCanvas.css" asp-append-version="true" />

    <canvas id="fog-canvas"></canvas>
    <script src="~/js/fogCanvas.js" asp-append-version="true"></script>

    <style>
        body {
            background-color: #000 !important;
            color: #fff;
        }
    </style>
}

<div class="d-flex justify-content-center align-items-center" style="min-height:80vh; position:relative; z-index:2;">
    <div class="hero-content text-center">
        <h2 class="glitch text-white mb-4">🛠 Dev - Скидання паролю</h2>

        @if (ViewBag.Message != null)
        {
            <div class="alert alert-info">@ViewBag.Message</div>
        }

        <form asp-action="DevResetPassword" method="post" class="login-form mx-auto">
            @Html.AntiForgeryToken()

            <div class="mb-3 text-start">
                <label>Email</label>
                <input name="email" class="form-control bg-dark text-light border-secondary" required />
            </div>
            <div class="mb-3 text-start">
                <label>Новий пароль</label>
                <input name="newPassword" type="password" class="form-control bg-dark text-light border-secondary" required />
            </div>
            <button class="btn btn-danger mt-2 w-100">Скинути пароль</button>
        </form>
    </div>
</div>
