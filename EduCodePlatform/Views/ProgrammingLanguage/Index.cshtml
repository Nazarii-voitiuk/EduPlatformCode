@{
    ViewData["Title"] = "Programming Languages";
}

<h2>Programming Languages</h2>

<!-- Кнопка "Create New" (без data-toggle), просто викликає openCreateModal() -->
<button type="button" class="btn btn-primary mb-3" onclick="openCreateModal()">
    Create New Language
</button>

<table class="table table-bordered" id="languageTable">
    <thead>
        <tr>
            <th>Language Id</th>
            <th>Name</th>
            <th style="width:200px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        <!-- Тут заповнюється AJAX-ом -->
    </tbody>
</table>

<!-- Модальне вікно (Bootstrap 5) -->
<div class="modal fade" id="languageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="languageModalLabel">Create/Edit Language</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="languageForm">
                    <input type="hidden" id="LanguageId" />
                    <div class="mb-3">
                        <label for="LanguageName" class="form-label">Name</label>
                        <input type="text" class="form-control" id="LanguageName" required />
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <!-- data-bs-dismiss="modal" просто закриє вікно -->
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="saveBtn" onclick="saveLanguage()">
                    Save
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Наш JS-файл із логікою AJAX (див. нижче) -->
    <script src="~/js/programmingLanguage.js"></script>
}
